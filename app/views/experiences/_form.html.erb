<%= form_with(model: [profile, experience], local: false, class: "instaform") do |form| %>
  <% translations = (profile ||= experience.profile).translations %>
  <%= render "shared/form_errors", item: experience if experience.errors.any? %>

  <%= translated_text_fields(form, :title, translations) %>
  <%= single_text_field(form, :location) %>
  <% # TODO: here it would be nice to have the birthday for a more specific date range %>
  <%= year_field_selection(form, [:year_begin, :year_end], 'experience.period', options: { min_year: 1980, max_year: Date.today.year }) %>
  <%= translated_rich_text_fields(form, :description, translations) %>

  <%= form_actions form, experience %>
<% end %>










