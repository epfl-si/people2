<%= form_with(model: [profile, box], local: false, class: "instaform") do |form| %>
    <% translations = (profile ||= box.profile).translations %>
  <%= render "shared/form_errors", item: box if box.errors.any? %>
  <% if box.new_record? %>
  <%= form.hidden_field :model_box_id %>
  <% end %>
  <% unless box.locked_title? %>
    <%= translated_text_fields(form, :title, translations) %>
  <% end %>
    <%= translated_rich_text_fields(form, :content, translations) %>
  <%= form_actions form, box, without_cancel: true %>
<% end %>
