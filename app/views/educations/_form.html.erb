<%= form_with(model: [profile, education], local: false, class: "instaform") do |form| %>
  <% translations = (profile ||= education.profile).translations %>
  <%= render "shared/form_errors", item: education if education.errors.any? %>

  <%= translated_text_fields(form, :title, translations) %>
  <%= translated_text_fields(form, :field, translations) %>

  <%= single_text_field(form, :director) %>
  <%= single_text_field(form, :school) %>
  <%= year_field_selection(form, [:year_begin, :year_end], 'education.year', options: { min_year: 1990, max_year: 2025 }) %>

  <% end %>
