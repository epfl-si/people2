<%= form_with(model: [@profile, @publication], local: false, class: "instaform") do |form| %>
  <% translations = (profile ||= publication.profile).translations %>
  <%= render "shared/form_errors", item: @publication if @publication.errors.any? %>

	<%= single_text_field(form, :title) %>
	<%= single_text_field(form, :journal) %>
	<%= single_text_field(form, :year) %>
	<%= single_text_field(form, :authors) %>
	<%= single_text_field(form, :url) %>

  <div class="form-group">
    <%= form.label :audience %>
    <%= audience_selector form %>
  </div>

  <%= form_actions form, @publication %>
<% end %>
